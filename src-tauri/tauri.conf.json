{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": ["resources/ffmpeg.exe", "resources/ffprobe.exe"]
  },
  "productName": "FFStudio",
  "mainBinaryName": "FFStudio",
  "version": "0.1.0",
  "identifier": "com.ffstudio.app",
  "plugins": {},
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "fullscreen": false,
        "resizable": true,
        "title": "FFStudio",
        "width": 1000,
        "height": 680,
        "minWidth": 780,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null
    }
  }
}