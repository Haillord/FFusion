{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "productName": "FFStudio",
  "mainBinaryName": "FFStudio",
  "version": "0.1.0",
  "identifier": "com.ffstudio.app",
  "plugins": {},
  "app": {
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "FFStudio",
        "width": 1000,
        "height": 680,
        "minWidth": 780,
        "minHeight": 520,
        "useHttpsScheme": true
      }
    ],
    "security": {
      "csp": null
    }
  }
}