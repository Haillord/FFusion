{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default-capability",
  "description": "Full access for FFStudio",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:all",
    "event:all",
    "fs:all",
    "shell:all",
    {
      "identifier": "fs:scope",
      "allow": ["**"]
    }
  ]
}